KMD
00000000:       ; ; 4-DIGIT MEMORY GAME FOR MU0
00000000:       ; ; Student: Aryan Sajiv, Student ID: 14308227
00000000:       ; ; Updated last by Aryan Sajiv on Nov 28th
00000000:       ; ; Game shows a random 4 digit number on display
00000000:       ; ; Player must type it back
00000000:       ; ; Green LED flashes if correct
00000000:       ; ; Red LED flashes if incorrect
00000000:       ; ; Buzzer beeps with different sounds for right and wrong answers
00000000:       ; 
00000000:       ; ; Peripheral addresses
00000000:       ; lights EQU &FFF
00000000:       ; keys EQU &FF2
00000000:       ; disp0 EQU &FF5
00000000:       ; disp1 EQU &FF6
00000000:       ; disp2 EQU &FF7
00000000:       ; disp3 EQU &FF8
00000000:       ; buzzer EQU &FFD
00000000:       ; 
00000000:       ; ORG &000
00000000:       ; 
00000000:       ; ; Main game loop
00000000:       ; MAIN
00000000:       ;     ; Generate random number
00000000: 045C  ;     LDA seed
00000001: 2467  ;     ADD step
00000002: 145C  ;     STA seed
00000003: 1458  ;     STA work
00000004:       ; 
00000004:       ;     ; Get thousands digit
00000004: 045D  ;     LDA zero
00000005: 1450  ;     STA num3
00000006:       ; G3
00000006: 0458  ;     LDA work
00000007: 3468  ;     SUB k1000
00000008: 500A  ;     JGE G3A
00000009: 400F  ;     JMP G2S
0000000A:       ; G3A
0000000A: 1458  ;     STA work
0000000B: 0450  ;     LDA num3
0000000C: 245E  ;     ADD one
0000000D: 1450  ;     STA num3
0000000E: 4006  ;     JMP G3
0000000F:       ; 
0000000F:       ;     ; Get hundreds digit
0000000F:       ; G2S
0000000F: 045D  ;     LDA zero
00000010: 1451  ;     STA num2
00000011:       ; G2
00000011: 0458  ;     LDA work
00000012: 3469  ;     SUB k100
00000013: 5015  ;     JGE G2A
00000014: 401A  ;     JMP G1S
00000015:       ; G2A
00000015: 1458  ;     STA work
00000016: 0451  ;     LDA num2
00000017: 245E  ;     ADD one
00000018: 1451  ;     STA num2
00000019: 4011  ;     JMP G2
0000001A:       ; 
0000001A:       ;     ; Get tens digit
0000001A:       ; G1S
0000001A: 045D  ;     LDA zero
0000001B: 1452  ;     STA num1
0000001C:       ; G1
0000001C: 0458  ;     LDA work
0000001D: 346A  ;     SUB k10
0000001E: 5020  ;     JGE G1A
0000001F: 4025  ;     JMP G0S
00000020:       ; G1A
00000020: 1458  ;     STA work
00000021: 0452  ;     LDA num1
00000022: 245E  ;     ADD one
00000023: 1452  ;     STA num1
00000024: 401C  ;     JMP G1
00000025:       ; 
00000025:       ;     ; Get units digit
00000025:       ; G0S
00000025: 0458  ;     LDA work
00000026: 1453  ;     STA num0
00000027:       ; 
00000027:       ;     ; Show number on display
00000027: 0450  ;     LDA num3
00000028: 1FF8  ;     STA disp3
00000029: 0451  ;     LDA num2
0000002A: 1FF7  ;     STA disp2
0000002B: 0452  ;     LDA num1
0000002C: 1FF6  ;     STA disp1
0000002D: 0453  ;     LDA num0
0000002E: 1FF5  ;     STA disp0
0000002F:       ; 
0000002F:       ;     ; Wait so player can see number
0000002F: 0479  ;     LDA outer
00000030: 145A  ;     STA cnt2
00000031:       ; DOUT
00000031: 0477  ;     LDA wait
00000032: 1459  ;     STA tmr
00000033:       ; DIN
00000033: 0459  ;     LDA tmr
00000034: 345E  ;     SUB one
00000035: 1459  ;     STA tmr
00000036: 6033  ;     JNE DIN
00000037: 045A  ;     LDA cnt2
00000038: 345E  ;     SUB one
00000039: 145A  ;     STA cnt2
0000003A: 6031  ;     JNE DOUT
0000003B:       ; 
0000003B:       ;     ; Clear display
0000003B: 045D  ;     LDA zero
0000003C: 1FF8  ;     STA disp3
0000003D: 1FF7  ;     STA disp2
0000003E: 1FF6  ;     STA disp1
0000003F: 1FF5  ;     STA disp0
00000040:       ; 
00000040:       ;     ; Read key 3
00000040:       ; R3
00000040: 0FF2  ;     LDA keys
00000041: 6043  ;     JNE P3
00000042: 4040  ;     JMP R3
00000043:       ; P3
00000043: 145B  ;     STA kval
00000044:       ; W3
00000044: 0FF2  ;     LDA keys
00000045: 6044  ;     JNE W3
00000046: 408E  ;     JMP C3
00000047:       ; 
00000047:       ;     ; Read key 2
00000047:       ; R2
00000047: 0FF2  ;     LDA keys
00000048: 604A  ;     JNE P2
00000049: 4047  ;     JMP R2
0000004A:       ; P2
0000004A: 145B  ;     STA kval
0000004B:       ; W2
0000004B: 0FF2  ;     LDA keys
0000004C: 604B  ;     JNE W2
0000004D: 40D8  ;     JMP C2
0000004E:       ; 
0000004E:       ;     ; Read key 1
0000004E:       ; R1
0000004E: 0FF2  ;     LDA keys
0000004F: 6051  ;     JNE P1
00000050: 404E  ;     JMP R1
00000051:       ; P1
00000051: 145B  ;     STA kval
00000052:       ; W1
00000052: 0FF2  ;     LDA keys
00000053: 6052  ;     JNE W1
00000054: 4122  ;     JMP C1
00000055:       ; 
00000055:       ;     ; Read key 0
00000055:       ; R0
00000055: 0FF2  ;     LDA keys
00000056: 6058  ;     JNE P0
00000057: 4055  ;     JMP R0
00000058:       ; P0
00000058: 145B  ;     STA kval
00000059:       ; W0
00000059: 0FF2  ;     LDA keys
0000005A: 6059  ;     JNE W0
0000005B: 416C  ;     JMP C0
0000005C:       ; 
0000005C:       ;     ; Compare input with target
0000005C:       ; CMP
0000005C: 0450  ;     LDA num3
0000005D: 3454  ;     SUB in3
0000005E: 607B  ;     JNE BAD
0000005F: 0451  ;     LDA num2
00000060: 3455  ;     SUB in2
00000061: 607B  ;     JNE BAD
00000062: 0452  ;     LDA num1
00000063: 3456  ;     SUB in1
00000064: 607B  ;     JNE BAD
00000065: 0453  ;     LDA num0
00000066: 3457  ;     SUB in0
00000067: 607B  ;     JNE BAD
00000068:       ; 
00000068:       ;     ; Correct - flash green, good beep
00000068:       ; WIN
00000068: 0475  ;     LDA green
00000069: 1FFF  ;     STA lights
0000006A: 047B  ;     LDA beepok
0000006B: 1FFD  ;     STA buzzer
0000006C: 047A  ;     LDA fout
0000006D: 145A  ;     STA cnt2
0000006E:       ; WON
0000006E: 0478  ;     LDA flash
0000006F: 1459  ;     STA tmr
00000070:       ; WO1
00000070: 0459  ;     LDA tmr
00000071: 345E  ;     SUB one
00000072: 1459  ;     STA tmr
00000073: 6070  ;     JNE WO1
00000074: 045A  ;     LDA cnt2
00000075: 345E  ;     SUB one
00000076: 145A  ;     STA cnt2
00000077: 606E  ;     JNE WON
00000078: 045D  ;     LDA zero
00000079: 1FFF  ;     STA lights
0000007A: 4000  ;     JMP MAIN
0000007B:       ; 
0000007B:       ;     ; Wrong - flash red, error beep
0000007B:       ; BAD
0000007B: 0476  ;     LDA red
0000007C: 1FFF  ;     STA lights
0000007D: 047C  ;     LDA beepno
0000007E: 1FFD  ;     STA buzzer
0000007F: 047A  ;     LDA fout
00000080: 145A  ;     STA cnt2
00000081:       ; LOS
00000081: 0478  ;     LDA flash
00000082: 1459  ;     STA tmr
00000083:       ; LO1
00000083: 0459  ;     LDA tmr
00000084: 345E  ;     SUB one
00000085: 1459  ;     STA tmr
00000086: 6083  ;     JNE LO1
00000087: 045A  ;     LDA cnt2
00000088: 345E  ;     SUB one
00000089: 145A  ;     STA cnt2
0000008A: 6081  ;     JNE LOS
0000008B: 045D  ;     LDA zero
0000008C: 1FFF  ;     STA lights
0000008D: 4000  ;     JMP MAIN
0000008E:       ; 
0000008E:       ; ; Convert key 3 bitmask to digit
0000008E:       ; C3
0000008E: 045B  ;     LDA kval
0000008F: 346B  ;     SUB b0
00000090: 6095  ;     JNE C3A
00000091: 045D  ;     LDA zero
00000092: 1454  ;     STA in3
00000093: 1FF8  ;     STA disp3
